        echo -e "${YELLOW}   Run 'conn key create' to generate a new ed25519 key pair.${NC}"
        echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        local confirm
        read -p "Do you want to continue anyway? (y/N): " confirm
        if [[ ! "$confirm" =~ ^[yY]$ ]]; then
            echo -e "${YELLOW}Connection cancelled.${NC}"
            return 0
        fi
        echo ""
    fi

    check_for_updates

    if ! _get_connection "$conn_alias"; then
        echo -e "${RED}Error: alias '$conn_alias' does not exist!${NC}"
        echo -e "${YELLOW}Use 'conn list' to see available connections.${NC}"
        return 1
    fi

    echo -e "${GREEN}Connecting to $conn_alias...${NC}"
    echo -e "  ${_c_user}@${_c_host}:${_c_port}"
    [ -n "$_c_folder" ] && echo -e "  ${YELLOW}📂 $_c_folder${NC}"
    [ -n "$_c_identity" ] && echo -e "  ${YELLOW}🔐 $_c_identity${NC}"
    [ -n "$_c_jump" ] && echo -e "  ${YELLOW}↪ $_c_jump${NC}"

    local password=""
    password=$(_secret_get "$conn_alias" 2>/dev/null) || true
    if [ -z "$password" ] && [ -n "${_c_legacy_password:-}" ]; then
        password="$_c_legacy_password"
    fi
    if [ -n "$password" ]; then
        if _copy_to_clipboard "$password"; then
            echo -e "  ${GREEN}✓ Password copied to clipboard!${NC}"
        else
            echo -e "  ${YELLOW}⚠  Cannot copy to clipboard (install pbcopy/xclip/xsel/wl-copy)${NC}"
        fi
    fi

    echo ""

    local -a ssh_cmd
    ssh_cmd=(ssh -p "$_c_port")
    [ -n "$_c_identity" ] && ssh_cmd+=(-i "$_c_identity")
    [ -n "$_c_jump" ] && ssh_cmd+=(-J "$_c_jump")

    if [ -n "$_c_folder" ]; then
        ssh_cmd+=(-t "${_c_user}@${_c_host}" "cd \"$_c_folder\" && exec \$SHELL -l")
    else
        ssh_cmd+=("${_c_user}@${_c_host}")
    fi

    "${ssh_cmd[@]}"
}

