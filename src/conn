_parse_userhost() {
    # Sets: _uh_user _uh_host _uh_port from user@host[:port]
    local spec="$1"
    _uh_user=""
    _uh_host=""
    _uh_port="22"

    if [[ "$spec" != *@* ]]; then
        echo -e "${RED}Error: expected user@host[:port], got '$spec'${NC}" >&2
        return 1
    fi

    _uh_user="${spec%%@*}"
    local rest="${spec#*@}"

    if [[ "$rest" == *:* ]] && [[ "$rest" != \[*\]* ]]; then
        # host:port (simple; IPv6 bracket form: [addr]:port)
        _uh_host="${rest%:*}"
        _uh_port="${rest##*:}"
    elif [[ "$rest" == \[*\]:* ]]; then
        _uh_host="${rest%:*}"
        _uh_port="${rest##*:}"
    else
        _uh_host="$rest"
    fi

    if [ -z "$_uh_user" ] || [ -z "$_uh_host" ]; then
        echo -e "${RED}Error: invalid user@host[:port] '$spec'${NC}" >&2
        return 1
    fi
    return 0
}

add_connection() {
    init_config

    local conn_alias="" user="" host="" port="22" folder="" identity="" jump="" password=""

    # One-shot: conn add alias user@host[:port] [--folder ...] [--identity ...] [--jump ...] [--password]
    if [ $# -ge 2 ] && [[ "$2" == *@* ]]; then
        conn_alias="$1"
        shift
        if ! _parse_userhost "$1"; then
            return 1
        fi
        shift
        user="$_uh_user"
        host="$_uh_host"
        port="$_uh_port"

        while [ $# -gt 0 ]; do
            case "$1" in
                --folder|-f)
                    folder="${2:-}"
                    shift 2
                    ;;
                --identity|-i)
                    identity="${2:-}"
                    shift 2
                    ;;
                --jump|-J)
                    jump="${2:-}"
                    shift 2
                    ;;
                --password|-p)
                    if [ -n "${2:-}" ] && [[ "${2:-}" != -* ]]; then
                        password="$2"
                        shift 2
                    else
                        read -s -p "Password: " password
                        echo ""
                        shift
                    fi
                    ;;
                *)
                    echo -e "${RED}Error: unknown option '$1'${NC}"
                    echo "Usage: conn add <alias> <user@host[:port]> [--folder PATH] [--identity FILE] [--jump HOST] [--password [PASS]]"
                    return 1
                    ;;
            esac
        done
    else
        echo -e "${BLUE}=== Add New SSH Connection ===${NC}"
        echo ""

        read -p "Type alias: " conn_alias
        if ! _validate_alias "$conn_alias"; then
            return 1
        fi

        if _connection_exists "$conn_alias"; then
            echo -e "${RED}Error: alias '$conn_alias' already exists!${NC}"
            return 1
        fi

        read -p "Type user (default: root): " user
        user=${user:-root}

        read -p "Type host: " host
        if [ -z "$host" ]; then
            echo -e "${RED}Error: host cannot be empty!${NC}"
            return 1
        fi

        read -p "Type port (default: 22): " port
        port=${port:-22}

        echo ""
        echo -e "${YELLOW}Password (optional — stored in secret store, copied to clipboard on connect):${NC}"
        read -s -p "Type password (optional): " password
        echo ""

        echo ""
        read -p "Type remote folder (optional): " folder

        read -p "Identity file (optional, e.g. ~/.ssh/id_ed25519): " identity
        read -p "ProxyJump host (optional): " jump
    fi

    if ! _validate_alias "$conn_alias"; then
        return 1
    fi
    if ! _validate_field "user" "$user" || ! _validate_field "host" "$host" \
        || ! _validate_field "folder" "$folder" || ! _validate_field "identity" "$identity" \
        || ! _validate_field "proxyjump" "$jump"; then
        return 1
    fi
    if ! _validate_port "$port"; then
        return 1
    fi

    if _connection_exists "$conn_alias"; then
        echo -e "${RED}Error: alias '$conn_alias' already exists!${NC}"
        return 1
    fi

    # Expand ~ in identity
    if [ -n "$identity" ]; then
        identity="$(_expand_path "$identity")"
    fi

    if [ -n "$password" ]; then
        if ! _secret_set "$conn_alias" "$password"; then
            echo -e "${RED}Error: failed to store password in secret store!${NC}"
            return 1
        fi
    fi

    _write_connection "$conn_alias" "$user" "$host" "$port" "$folder" "$identity" "$jump"

    echo ""
    echo -e "${GREEN}✓ Connection '$conn_alias' added successfully!${NC}"
    echo -e "  ${user}@${host}:${port}"
    [ -n "$folder" ] && echo -e "  ${YELLOW}(will open in $folder)${NC}"
    [ -n "$identity" ] && echo -e "  ${YELLOW}(identity: $identity)${NC}"
    [ -n "$jump" ] && echo -e "  ${YELLOW}(proxyjump: $jump)${NC}"
    [ -n "$password" ] && echo -e "  ${YELLOW}(password stored in $(_secret_backend))${NC}"
    echo ""
}

edit_connection() {
    init_config

    local old_alias="${1:-}"
    if [ -z "$old_alias" ]; then
        echo -e "${RED}Error: please specify an alias!${NC}"
        echo "Usage: conn edit <alias>"
        return 1
    fi

    if ! _get_connection "$old_alias"; then
        echo -e "${RED}Error: alias '$old_alias' does not exist!${NC}"
        return 1
    fi

    local current_alias="$_c_alias"
    local current_user="$_c_user"
    local current_host="$_c_host"
    local current_port="$_c_port"
    local current_folder="$_c_folder"
    local current_identity="$_c_identity"
    local current_jump="$_c_jump"

    echo -e "${BLUE}=== Edit SSH Connection ===${NC}"
    echo ""
    echo -e "${YELLOW}Press Enter to keep the current value${NC}"
    echo ""

    local new_alias new_user new_host new_port new_password new_folder new_identity new_jump

    read -p "Alias ($current_alias): " new_alias
    new_alias=${new_alias:-$current_alias}

    if [ "$new_alias" != "$current_alias" ]; then
        if ! _validate_alias "$new_alias"; then
            return 1
        fi
        if _connection_exists "$new_alias"; then
            echo -e "${RED}Error: alias '$new_alias' already exists!${NC}"
            return 1
        fi
    fi

    read -p "User ($current_user): " new_user
    new_user=${new_user:-$current_user}

    read -p "Host ($current_host): " new_host
    new_host=${new_host:-$current_host}

    read -p "Port ($current_port): " new_port
    new_port=${new_port:-$current_port}
    if ! _validate_port "$new_port"; then
        return 1
    fi

    echo ""
    if _secret_has "$current_alias" 2>/dev/null; then
        echo -e "${YELLOW}Password (saved in secret store; Enter=keep, 'REMOVE'=delete):${NC}"
    else
        echo -e "${YELLOW}Password (optional — stored in secret store):${NC}"
    fi
    read -s -p "Type password: " new_password
    echo ""

    echo ""
    if [ -n "$current_folder" ]; then
        echo -e "${YELLOW}Remote folder (current: $current_folder, Enter=keep, 'REMOVE'=delete):${NC}"
    else
        echo -e "${YELLOW}Remote folder (optional):${NC}"
    fi
    read -p "Type remote folder: " new_folder
    if [ -z "$new_folder" ]; then
        new_folder="$current_folder"
    elif [ "$new_folder" = "REMOVE" ]; then
        new_folder=""
    fi

    if [ -n "$current_identity" ]; then
        echo -e "${YELLOW}Identity file (current: $current_identity, Enter=keep, 'REMOVE'=delete):${NC}"
    else
        echo -e "${YELLOW}Identity file (optional):${NC}"
    fi
    read -p "Type identity file: " new_identity
    if [ -z "$new_identity" ]; then
        new_identity="$current_identity"
    elif [ "$new_identity" = "REMOVE" ]; then
        new_identity=""
    fi
    if [ -n "$new_identity" ]; then
        new_identity="$(_expand_path "$new_identity")"
    fi

    if [ -n "$current_jump" ]; then
        echo -e "${YELLOW}ProxyJump (current: $current_jump, Enter=keep, 'REMOVE'=delete):${NC}"
    else
        echo -e "${YELLOW}ProxyJump (optional):${NC}"
    fi
    read -p "Type ProxyJump host: " new_jump
    if [ -z "$new_jump" ]; then
        new_jump="$current_jump"
    elif [ "$new_jump" = "REMOVE" ]; then
        new_jump=""
    fi

    if ! _validate_field "user" "$new_user" || ! _validate_field "host" "$new_host" \
        || ! _validate_field "folder" "$new_folder" || ! _validate_field "identity" "$new_identity" \
        || ! _validate_field "proxyjump" "$new_jump"; then
        return 1
    fi

    _delete_connection_line "$old_alias"
    _write_connection "$new_alias" "$new_user" "$new_host" "$new_port" "$new_folder" "$new_identity" "$new_jump"

    # Password / secret store
    if [ "$new_password" = "REMOVE" ]; then
        _secret_delete "$current_alias"
        [ "$new_alias" != "$current_alias" ] && _secret_delete "$new_alias"
    elif [ -n "$new_password" ]; then
        [ "$new_alias" != "$current_alias" ] && _secret_delete "$current_alias"
        _secret_set "$new_alias" "$new_password"
    elif [ "$new_alias" != "$current_alias" ]; then
        # Rename secret entry
        local old_pw
        if old_pw=$(_secret_get "$current_alias" 2>/dev/null); then
            _secret_set "$new_alias" "$old_pw"
            _secret_delete "$current_alias"
        fi
    fi

    echo ""
    echo -e "${GREEN}✓ Connection updated successfully!${NC}"
    if [ "$new_alias" != "$current_alias" ]; then
        echo -e "  ${YELLOW}Alias changed: $current_alias → $new_alias${NC}"
    fi
    echo -e "  ${new_user}@${new_host}:${new_port}"
    [ -n "$new_folder" ] && echo -e "  ${YELLOW}(will open in $new_folder)${NC}"
    [ -n "$new_identity" ] && echo -e "  ${YELLOW}(identity: $new_identity)${NC}"
    [ -n "$new_jump" ] && echo -e "  ${YELLOW}(proxyjump: $new_jump)${NC}"
    echo ""
}

