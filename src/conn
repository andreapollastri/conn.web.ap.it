#!/bin/bash

# conn — SSH Connection Manager
# Config:  ~/.ssh_connections.conf
# Format:  alias|user|host|port|folder|identity|proxyjump
# Secrets: OS keychain / secret-tool / pass / ~/.ssh_connections.secrets (chmod 600)

CONFIG_FILE="${CONN_CONFIG_FILE:-$HOME/.ssh_connections.conf}"
SECRETS_FILE="${CONN_SECRETS_FILE:-$HOME/.ssh_connections.secrets}"
UPDATE_CACHE_FILE="${CONN_UPDATE_CACHE:-$HOME/.cache/conn/last_update_check}"
UPDATE_CACHE_TTL="${CONN_UPDATE_TTL:-86400}"
SECRET_SERVICE="conn.web.ap.it"
REPO_OWNER="andreapollastri"
REPO_NAME="conn.web.ap.it"
REPO_FILE="src/conn"
# Fallback only — prefer SHA URL from GitHub API (branch raw CDN can stay stale).
REPO_URL="https://cdn.jsdelivr.net/gh/${REPO_OWNER}/${REPO_NAME}@main/${REPO_FILE}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

init_config() {
    local dir
    dir="$(dirname "$CONFIG_FILE")"
    mkdir -p "$dir" 2>/dev/null || true
    if [ ! -f "$CONFIG_FILE" ]; then
        touch "$CONFIG_FILE"
        chmod 600 "$CONFIG_FILE"
        echo -e "${GREEN}Configuration file created: $CONFIG_FILE${NC}"
    else
        chmod 600 "$CONFIG_FILE" 2>/dev/null || true
    fi
    _migrate_config_if_needed
}

_field_has_pipe() {
    case "$1" in
        *'|'*) return 0 ;;
        *) return 1 ;;
    esac
}

_validate_field() {
    local name="$1"
    local value="$2"
    if _field_has_pipe "$value"; then
        echo -e "${RED}Error: $name cannot contain '|'${NC}" >&2
        return 1
    fi
    return 0
}

_validate_alias() {
    local a="$1"
    if [ -z "$a" ]; then
        echo -e "${RED}Error: alias cannot be empty!${NC}" >&2
        return 1
    fi
    if ! _validate_field "alias" "$a"; then
        return 1
    fi
    case "$a" in
        *[[:space:]]*)
            echo -e "${RED}Error: alias cannot contain spaces!${NC}" >&2
            return 1
            ;;
    esac
    return 0
}

_validate_port() {
    local p="$1"
    case "$p" in
        ''|*[!0-9]*)
            echo -e "${RED}Error: port must be a number!${NC}" >&2
            return 1
            ;;
    esac
    if [ "$p" -lt 1 ] || [ "$p" -gt 65535 ]; then
        echo -e "${RED}Error: port must be between 1 and 65535!${NC}" >&2
        return 1
    fi
    return 0
}

# Count pipe separators in a config line
_pipe_count() {
    awk -F'|' '{print NF-1}' <<< "$1"
}

# Expand a leading ~/ to $HOME (portable — avoids ${var/#\~/} quirks)
_expand_path() {
    local p="$1"
    case "$p" in
        "~") p="$HOME" ;;
        "~/"*) p="$HOME/${p#~/}" ;;
    esac
    printf '%s' "$p"
}

# Parse a config line into globals: _c_alias _c_user _c_host _c_port _c_folder _c_identity _c_jump
# Legacy (< 6 pipes): alias|user|host|port|[password]|[folder]
# Current (6 pipes):  alias|user|host|port|folder|identity|proxyjump
_parse_line() {
    local line="$1"
    local f1 f2 f3 f4 f5 f6 f7 pipes
    IFS='|' read -r f1 f2 f3 f4 f5 f6 f7 <<< "$line"
    pipes="$(_pipe_count "$line")"

    _c_alias="$f1"
    _c_user="$f2"
    _c_host="$f3"
    _c_port="$f4"
    _c_folder=""
    _c_identity=""
    _c_jump=""
    _c_legacy_password=""

    if [ "$pipes" -ge 6 ]; then
        _c_folder="$f5"
        _c_identity="$f6"
        _c_jump="$f7"
    else
        # 3 pipes: alias|user|host|port
        # 4 pipes: alias|user|host|port|password
        # 5 pipes: alias|user|host|port|password|folder
        _c_legacy_password="$f5"
        _c_folder="$f6"
    fi
}

_format_line() {
    local a="$1" u="$2" h="$3" p="$4" f="$5" i="$6" j="$7"
    printf '%s|%s|%s|%s|%s|%s|%s\n' "$a" "$u" "$h" "$p" "$f" "$i" "$j"
}

_get_connection() {
    local needle="$1"
    local line
    _c_alias="" _c_user="" _c_host="" _c_port="" _c_folder="" _c_identity="" _c_jump="" _c_legacy_password=""

    [ ! -f "$CONFIG_FILE" ] && return 1

    while IFS= read -r line || [ -n "$line" ]; do
        [ -z "$line" ] && continue
        case "$line" in
            \#*) continue ;;
        esac
        if [ "${line%%|*}" = "$needle" ]; then
            _parse_line "$line"
            return 0
        fi
    done < "$CONFIG_FILE"
    return 1
}

_connection_exists() {
    _get_connection "$1"
}

_delete_connection_line() {
    local needle="$1"
    local tmp line
    tmp=$(mktemp) || return 1

    while IFS= read -r line || [ -n "$line" ]; do
        [ -z "$line" ] && continue
        if [ "${line%%|*}" = "$needle" ]; then
            continue
        fi
        printf '%s\n' "$line" >> "$tmp"
    done < "$CONFIG_FILE"

    mv "$tmp" "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE"
}

_write_connection() {
    local a="$1" u="$2" h="$3" p="$4" f="$5" i="$6" j="$7"
    _format_line "$a" "$u" "$h" "$p" "$f" "$i" "$j" >> "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE"
}

_migrate_config_if_needed() {
    [ ! -s "$CONFIG_FILE" ] && return 0

    local line pipes needs_migrate=0
    while IFS= read -r line || [ -n "$line" ]; do
        [ -z "$line" ] && continue
        case "$line" in \#*) continue ;; esac
        pipes="$(_pipe_count "$line")"
        # Anything with fewer than 6 pipes is legacy (with or without folder).
        if [ "$pipes" -lt 6 ]; then
            needs_migrate=1
            break
        fi
    done < "$CONFIG_FILE"

    [ "$needs_migrate" -eq 0 ] && return 0

    local tmp a u h p pw f migrated=0
    tmp=$(mktemp) || return 1

    while IFS= read -r line || [ -n "$line" ]; do
        [ -z "$line" ] && continue
        case "$line" in \#*) printf '%s\n' "$line" >> "$tmp"; continue ;; esac

        pipes="$(_pipe_count "$line")"
        if [ "$pipes" -ge 6 ]; then
            printf '%s\n' "$line" >> "$tmp"
            continue
        fi

        IFS='|' read -r a u h p pw f <<< "$line"
        if [ -n "$pw" ]; then
            if ! _secret_set "$a" "$pw"; then
                echo -e "${YELLOW}Warning: could not migrate password for '$a' to secret store; using secrets file fallback.${NC}" >&2
                _secret_file_set "$a" "$pw"
            fi
        fi
        _format_line "$a" "$u" "$h" "$p" "$f" "" "" >> "$tmp"
        migrated=1
    done < "$CONFIG_FILE"

    mv "$tmp" "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE"
    if [ "$migrated" -eq 1 ]; then
        echo -e "${GREEN}✓ Migrated config to secure format (passwords moved out of $CONFIG_FILE).${NC}" >&2
    fi
}

# ---------------------------------------------------------------------------
# Secret storage
# ---------------------------------------------------------------------------

_secret_backend() {
    if [[ "$OSTYPE" == darwin* ]] && command -v security >/dev/null 2>&1; then
        echo "keychain"
    elif command -v secret-tool >/dev/null 2>&1; then
        echo "secret-tool"
    elif command -v pass >/dev/null 2>&1; then
        echo "pass"
    else
        echo "file"
    fi
}

_secret_file_set() {
    local account="$1" password="$2"
    local tmp line
    mkdir -p "$(dirname "$SECRETS_FILE")" 2>/dev/null || true
    touch "$SECRETS_FILE"
    chmod 600 "$SECRETS_FILE"
    tmp=$(mktemp) || return 1
    while IFS= read -r line || [ -n "$line" ]; do
        [ -z "$line" ] && continue
        [ "${line%%|*}" = "$account" ] && continue
        printf '%s\n' "$line" >> "$tmp"
    done < "$SECRETS_FILE"
    if [ -n "$password" ]; then
        # Store password after first |; allow | inside password via rest of line
        printf '%s|%s\n' "$account" "$password" >> "$tmp"
    fi
    mv "$tmp" "$SECRETS_FILE"
    chmod 600 "$SECRETS_FILE"
}

_secret_file_get() {
    local account="$1"
    local line
    [ ! -f "$SECRETS_FILE" ] && return 1
    while IFS= read -r line || [ -n "$line" ]; do
        [ -z "$line" ] && continue
        if [ "${line%%|*}" = "$account" ]; then
            printf '%s' "${line#*|}"
            return 0
        fi
    done < "$SECRETS_FILE"
    return 1
}

_secret_file_delete() {
    local account="$1"
    [ ! -f "$SECRETS_FILE" ] && return 0
    _secret_file_set "$account" ""
}

_secret_set() {
    local account="$1" password="$2"
    local backend
    backend="$(_secret_backend)"

    case "$backend" in
        keychain)
            security add-generic-password -U -s "$SECRET_SERVICE" -a "$account" -w "$password" >/dev/null 2>&1
            ;;
        secret-tool)
            printf '%s' "$password" | secret-tool store --label="conn $account" service "$SECRET_SERVICE" account "$account"
            ;;
        pass)
            printf '%s\n' "$password" | pass insert -m -f "conn/$account" >/dev/null 2>&1
            ;;
        file)
            echo -e "${YELLOW}Note: no OS keychain found; storing password in $SECRETS_FILE (chmod 600).${NC}" >&2
            _secret_file_set "$account" "$password"
            ;;
    esac
}

_secret_get() {
    local account="$1"
    local backend pw
    backend="$(_secret_backend)"

    case "$backend" in
        keychain)
            pw=$(security find-generic-password -s "$SECRET_SERVICE" -a "$account" -w 2>/dev/null) || return 1
            printf '%s' "$pw"
            return 0
            ;;
        secret-tool)
            pw=$(secret-tool lookup service "$SECRET_SERVICE" account "$account" 2>/dev/null) || return 1
            printf '%s' "$pw"
            return 0
            ;;
        pass)
            pw=$(pass show "conn/$account" 2>/dev/null | head -n1) || return 1
            printf '%s' "$pw"
            return 0
            ;;
        file)
            _secret_file_get "$account"
            ;;
    esac
}

_secret_has() {
    local pw
    pw=$(_secret_get "$1" 2>/dev/null) || return 1
    [ -n "$pw" ]
}

_secret_delete() {
    local account="$1"
    local backend
    backend="$(_secret_backend)"

    case "$backend" in
        keychain)
            security delete-generic-password -s "$SECRET_SERVICE" -a "$account" >/dev/null 2>&1 || true
            ;;
        secret-tool)
            secret-tool clear service "$SECRET_SERVICE" account "$account" >/dev/null 2>&1 || true
            ;;
        pass)
            pass rm -f "conn/$account" >/dev/null 2>&1 || true
            ;;
        file)
            _secret_file_delete "$account"
            ;;
    esac
    # Always clean file fallback too
    _secret_file_delete "$account" 2>/dev/null || true
}

_copy_to_clipboard() {
    local text="$1"
    if [[ "$OSTYPE" == darwin* ]] && command -v pbcopy >/dev/null 2>&1; then
        printf '%s' "$text" | pbcopy
        return 0
    elif command -v xclip >/dev/null 2>&1; then
        printf '%s' "$text" | xclip -selection clipboard
        return 0
    elif command -v xsel >/dev/null 2>&1; then
        printf '%s' "$text" | xsel --clipboard --input
        return 0
    elif command -v wl-copy >/dev/null 2>&1; then
        printf '%s' "$text" | wl-copy
        return 0
    fi
    return 1
}

# ---------------------------------------------------------------------------
# SSH key helpers
# ---------------------------------------------------------------------------

_default_private_key() {
    if [ -f "$HOME/.ssh/id_ed25519" ]; then
        echo "$HOME/.ssh/id_ed25519"
    elif [ -f "$HOME/.ssh/id_ecdsa" ]; then
        echo "$HOME/.ssh/id_ecdsa"
    elif [ -f "$HOME/.ssh/id_rsa" ]; then
        echo "$HOME/.ssh/id_rsa"
    else
        echo ""
    fi
}

_default_public_key() {
    local priv
    priv="$(_default_private_key)"
    if [ -n "$priv" ] && [ -f "${priv}.pub" ]; then
        echo "${priv}.pub"
    else
        echo ""
    fi
}

_has_ssh_key() {
    local k
    k="$(_default_private_key)"
    [ -n "$k" ]
}

# Resolve a fresh download URL for src/conn.
# raw.githubusercontent.com/.../main/... is CDN-cached and often lags behind pushes;
# pin to the latest commit SHA (immutable) when the API is reachable.
_remote_script_url() {
    local sha="" api
    api="https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/commits/main"
    if command -v curl >/dev/null 2>&1; then
        sha=$(curl -fsSL --connect-timeout 3 --max-time 8 "$api" 2>/dev/null \
            | grep -o '"sha"[[:space:]]*:[[:space:]]*"[0-9a-f]\{40\}"' \
            | head -1 \
            | grep -o '[0-9a-f]\{40\}')
    elif command -v wget >/dev/null 2>&1; then
        sha=$(wget -q -T 8 -O - "$api" 2>/dev/null \
            | grep -o '"sha"[[:space:]]*:[[:space:]]*"[0-9a-f]\{40\}"' \
            | head -1 \
            | grep -o '[0-9a-f]\{40\}')
    fi
    if [ -n "$sha" ]; then
        printf 'https://raw.githubusercontent.com/%s/%s/%s/%s' \
            "$REPO_OWNER" "$REPO_NAME" "$sha" "$REPO_FILE"
    else
        printf '%s' "$REPO_URL"
    fi
}

_download_remote_script() {
    local dest="$1"
    local url
    url="$(_remote_script_url)"
    if command -v curl >/dev/null 2>&1; then
        curl -fsSL --connect-timeout 5 --max-time 30 \
            -H 'Cache-Control: no-cache' -H 'Pragma: no-cache' \
            "$url" -o "$dest"
    elif command -v wget >/dev/null 2>&1; then
        wget -q -T 30 --no-cache -O "$dest" "$url"
    else
        return 1
    fi
}

_resolve_script_path() {
    local path=""
    if command -v realpath >/dev/null 2>&1; then
        path="$(realpath "$0" 2>/dev/null)"
    elif command -v greadlink >/dev/null 2>&1; then
        path="$(greadlink -f "$0" 2>/dev/null)"
    elif command -v readlink >/dev/null 2>&1 && readlink -f "$0" >/dev/null 2>&1; then
        path="$(readlink -f "$0" 2>/dev/null)"
    fi

    if [ -z "$path" ] || [ ! -f "$path" ]; then
        if [ -L "$0" ]; then
            path="$(ls -l "$0" 2>/dev/null | awk '{print $NF}')"
            if [ -n "$path" ] && [[ "$path" != /* ]]; then
                path="$(cd "$(dirname "$0")" && pwd)/$path"
            fi
        else
            path="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
        fi
    fi

    if [ -n "$path" ] && [ -f "$path" ]; then
        printf '%s' "$path"
        return 0
    fi
    return 1
}

_truncate_cell() {
    local s="$1"
    local max="$2"
    local len=${#s}
    if [ "$len" -gt "$max" ]; then
        echo "${s:0:$((max - 3))}..."
    else
        echo "$s"
    fi
}

_repeat_char() {
    local n="$1"
    local c="${2:--}"
    local out=""
    local i
    for ((i = 0; i < n; i++)); do
        out+="$c"
    done
    printf '%s' "$out"
}

# Display width of Notes icons. macOS/BSD printf %-Ns pads by bytes, not
# terminal columns, so emoji break box-drawing tables unless we pad manually.
_notes_display_width() {
    local notes="$1"
    local w=0
    local t="$notes"
    while [ -n "$t" ]; do
        case "$t" in
            🔑*) w=$((w + 2)); t="${t#🔑}" ;;
            📂*) w=$((w + 2)); t="${t#📂}" ;;
            🔐*) w=$((w + 2)); t="${t#🔐}" ;;
            ↪*)  w=$((w + 1)); t="${t#↪}" ;;
            *)   w=$((w + 1)); t="${t:1}" ;;
        esac
    done
    printf '%s' "$w"
}

_pad_notes_cell() {
    local notes="$1"
    local width="$2"
    local dw pad
    dw=$(_notes_display_width "$notes")
    pad=$((width - dw))
    [ "$pad" -lt 0 ] && pad=0
    printf '%s%*s' "$notes" "$pad" ''
}

# ---------------------------------------------------------------------------
# Help / completion
# ---------------------------------------------------------------------------

show_help() {
    echo -e "${BLUE}=== SSH Connection Manager ===${NC}"
    echo ""
    echo "Usage: conn <command> [options]"
    echo ""
    echo "Available commands:"
    echo "  to <alias>              - Connect to the server with the specified alias"
    echo "  list                    - Show the list of all configured servers"
    echo "  info <alias>            - Show detailed information about a connection"
    echo "  add [alias user@host[:port]]"
    echo "                          - Add a connection (wizard or one-shot)"
    echo "  edit <alias>            - Edit an existing connection"
    echo "  remove <alias>          - Remove an existing connection"
    echo "  reset <alias>           - Remove SSH host key for the specified alias"
    echo "  key <action>            - Manage SSH keys (public|private|create [--rsa])"
    echo "  update                  - Update the script to the latest version from GitHub"
    echo "  completion [bash|zsh]  - Print shell completion script"
    echo "  help                    - Show this help message"
    echo ""
    echo "One-shot add options:"
    echo "  conn add prod deploy@host:22 --folder /var/www --identity ~/.ssh/id_ed25519 --jump bastion"
    echo ""
    echo -e "${YELLOW}Tip:${NC} Connections file:"
    echo "  $CONFIG_FILE"
    echo -e "${YELLOW}Note:${NC} Passwords are stored in the OS secret store (Keychain / secret-tool / pass),"
    echo "      never in the connections file. Copied to clipboard on connect (🔑)."
    echo -e "${YELLOW}Note:${NC} Remote folders allow auto-cd on connect (📂)."
    echo -e "${YELLOW}Note:${NC} Optional IdentityFile (🔐) and ProxyJump (↪) per connection."
    echo ""
}

print_completion() {
    local shell="${1:-}"
    if [ -z "$shell" ]; then
        if [ -n "$ZSH_VERSION" ]; then
            shell="zsh"
        else
            shell="bash"
        fi
    fi

    case "$shell" in
        bash)
            cat <<'EOF'
_conn_completions() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local cmd="${COMP_WORDS[1]}"
    local aliases
    aliases=$(conn list --aliases 2>/dev/null)

    case "${COMP_CWORD}" in
        1)
            COMPREPLY=( $(compgen -W "to list info add edit remove reset key update completion help" -- "$cur") )
            ;;
        2)
            case "$cmd" in
                to|info|edit|remove|reset)
                    COMPREPLY=( $(compgen -W "$aliases" -- "$cur") )
                    ;;
                key)
                    COMPREPLY=( $(compgen -W "public private create" -- "$cur") )
                    ;;
                completion)
                    COMPREPLY=( $(compgen -W "bash zsh" -- "$cur") )
                    ;;
            esac
            ;;
        3)
            if [ "$cmd" = "key" ] && [ "${COMP_WORDS[2]}" = "create" ]; then
                COMPREPLY=( $(compgen -W "--rsa" -- "$cur") )
            fi
            ;;
    esac
}
complete -F _conn_completions conn
EOF
            ;;
        zsh)
            cat <<'EOF'
#compdef conn
_conn() {
    local -a commands aliases key_actions
    commands=(to list info add edit remove reset key update completion help)
    key_actions=(public private create)
    aliases=(${(f)"$(conn list --aliases 2>/dev/null)"})

    case $CURRENT in
        2)
            _describe 'command' commands
            ;;
        3)
            case ${words[2]} in
                to|info|edit|remove|reset)
                    _describe 'alias' aliases
                    ;;
                key)
                    _describe 'action' key_actions
                    ;;
                completion)
                    _values 'shell' bash zsh
                    ;;
            esac
            ;;
        4)
            if [[ ${words[2]} == key && ${words[3]} == create ]]; then
                _values 'option' --rsa
            fi
            ;;
    esac
}
compdef _conn conn
EOF
            ;;
        *)
            echo -e "${RED}Error: unsupported shell '$shell' (use bash or zsh)${NC}" >&2
            return 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

list_connections() {
    init_config

    if [ "${1:-}" = "--aliases" ]; then
        if [ ! -s "$CONFIG_FILE" ]; then
            return 0
        fi
        local line
        while IFS= read -r line || [ -n "$line" ]; do
            [ -z "$line" ] && continue
            case "$line" in \#*) continue ;; esac
            printf '%s\n' "${line%%|*}"
        done < <(sort "$CONFIG_FILE")
        return 0
    fi

    if [ ! -s "$CONFIG_FILE" ]; then
        echo -e "${YELLOW}No connections configured.${NC}"
        echo -e "${YELLOW}Use 'conn add' to add a new connection.${NC}"
        return
    fi

    local W_ALIAS=14 W_USER=8 W_HOST=16 W_PORT=4 W_FOLDER=20 W_NOTES=12
    local line

    while IFS= read -r line || [ -n "$line" ]; do
        [ -z "$line" ] && continue
        case "$line" in \#*) continue ;; esac
        _parse_line "$line"
        [ ${#_c_alias} -gt "$W_ALIAS" ] && W_ALIAS=${#_c_alias}
        [ ${#_c_user} -gt "$W_USER" ] && W_USER=${#_c_user}
        [ ${#_c_host} -gt "$W_HOST" ] && W_HOST=${#_c_host}
        [ ${#_c_port} -gt "$W_PORT" ] && W_PORT=${#_c_port}
        if [ -n "$_c_folder" ]; then
            [ ${#_c_folder} -gt "$W_FOLDER" ] && W_FOLDER=${#_c_folder}
        fi
    done < <(sort "$CONFIG_FILE")

    [ "$W_ALIAS" -gt 24 ] && W_ALIAS=24
    [ "$W_USER" -gt 20 ] && W_USER=20
    [ "$W_HOST" -gt 36 ] && W_HOST=36
    [ "$W_PORT" -gt 5 ] && W_PORT=5
    [ "$W_FOLDER" -gt 32 ] && W_FOLDER=32

    local border_len=$((13 + W_ALIAS + W_USER + W_HOST + W_PORT + W_FOLDER + W_NOTES))
    local title_bar
    title_bar=$(_repeat_char $((border_len - 2)) "═")

    echo ""
    echo -e "${BLUE}╔${title_bar}╗${NC}"
    printf "${BLUE}║ %-$((border_len - 4))s ║${NC}\n" " SSH SERVERS LIST"
    echo -e "${BLUE}╚${title_bar}╝${NC}"
    echo ""

    local h_alias h_user h_host h_port h_folder
    h_alias=$(_truncate_cell "Alias" "$W_ALIAS")
    h_user=$(_truncate_cell "User" "$W_USER")
    h_host=$(_truncate_cell "Host" "$W_HOST")
    h_port=$(_truncate_cell "Port" "$W_PORT")
    h_folder=$(_truncate_cell "Remote folder" "$W_FOLDER")

    local top mid bot
    top="┌$(_repeat_char 5 '─')┬$(_repeat_char "$W_ALIAS" '─')┬$(_repeat_char "$W_USER" '─')┬$(_repeat_char "$W_HOST" '─')┬$(_repeat_char "$W_PORT" '─')┬$(_repeat_char "$W_FOLDER" '─')┬$(_repeat_char "$W_NOTES" '─')┐"
    mid="├$(_repeat_char 5 '─')┼$(_repeat_char "$W_ALIAS" '─')┼$(_repeat_char "$W_USER" '─')┼$(_repeat_char "$W_HOST" '─')┼$(_repeat_char "$W_PORT" '─')┼$(_repeat_char "$W_FOLDER" '─')┼$(_repeat_char "$W_NOTES" '─')┤"
    bot="└$(_repeat_char 5 '─')┴$(_repeat_char "$W_ALIAS" '─')┴$(_repeat_char "$W_USER" '─')┴$(_repeat_char "$W_HOST" '─')┴$(_repeat_char "$W_PORT" '─')┴$(_repeat_char "$W_FOLDER" '─')┴$(_repeat_char "$W_NOTES" '─')┘"

    local h_notes
    h_notes=$(_pad_notes_cell "Notes" "$W_NOTES")

    echo -e "${BLUE}${top}${NC}"
    printf "${BLUE}│${NC}%5s${BLUE}│${NC}%-${W_ALIAS}s${BLUE}│${NC}%-${W_USER}s${BLUE}│${NC}%-${W_HOST}s${BLUE}│${NC}%-${W_PORT}s${BLUE}│${NC}%-${W_FOLDER}s${BLUE}│${NC}%s${BLUE}│${NC}\n" \
        "#" "$h_alias" "$h_user" "$h_host" "$h_port" "$h_folder" "$h_notes"
    echo -e "${BLUE}${mid}${NC}"

    local idx=0 line notes ca cu ch cp cf cn
    while IFS= read -r line || [ -n "$line" ]; do
        [ -z "$line" ] && continue
        case "$line" in \#*) continue ;; esac
        _parse_line "$line"
        idx=$((idx + 1))

        notes=""
        _secret_has "$_c_alias" 2>/dev/null && notes+="🔑"
        [ -n "$_c_folder" ] && notes+="📂"
        [ -n "$_c_identity" ] && notes+="🔐"
        [ -n "$_c_jump" ] && notes+="↪"
        [ -z "$notes" ] && notes="-"

        ca=$(_truncate_cell "$_c_alias" "$W_ALIAS")
        cu=$(_truncate_cell "$_c_user" "$W_USER")
        ch=$(_truncate_cell "$_c_host" "$W_HOST")
        cp=$(_truncate_cell "$_c_port" "$W_PORT")
        if [ -n "$_c_folder" ]; then
            cf=$(_truncate_cell "$_c_folder" "$W_FOLDER")
        else
            cf=$(_truncate_cell "-" "$W_FOLDER")
        fi
        cn=$(_pad_notes_cell "$notes" "$W_NOTES")

        printf "${BLUE}│${NC}${GREEN}%5d${NC}${BLUE}│${NC}%-${W_ALIAS}s${BLUE}│${NC}%-${W_USER}s${BLUE}│${NC}%-${W_HOST}s${BLUE}│${NC}%-${W_PORT}s${BLUE}│${NC}%-${W_FOLDER}s${BLUE}│${NC}%s${BLUE}│${NC}\n" \
            "$idx" "$ca" "$cu" "$ch" "$cp" "$cf" "$cn"
    done < <(sort "$CONFIG_FILE")

    echo -e "${BLUE}${bot}${NC}"
    echo ""
    echo -e "${BLUE}$(_repeat_char "$border_len" "─")${NC}"
    echo -e "  ${YELLOW}💡 Tip:${NC} Use ${GREEN}conn to <alias>${NC} to connect"
    echo -e "  ${YELLOW}🔑${NC} saved password   ${YELLOW}📂${NC} remote folder   ${YELLOW}🔐${NC} identity file   ${YELLOW}↪${NC} proxy jump"
    echo ""
}

