manage_keys() {
    local action="${1:-}"
    shift || true
    local key_path pub_path
    local key_type="ed25519"
    local new_key comment
    local confirm

    key_path="$(_default_private_key)"
    if [ -z "$key_path" ]; then
        key_path="$HOME/.ssh/id_ed25519"
    fi
    pub_path="${key_path}.pub"

    if [ -z "$action" ]; then
        echo -e "${RED}Error: please specify an action!${NC}"
        echo "Usage: conn key <public|private|create [--rsa]>"
        return 1
    fi

    case "$action" in
        public)
            pub_path="$(_default_public_key)"
            if [ -z "$pub_path" ] || [ ! -f "$pub_path" ]; then
                echo -e "${RED}Error: SSH public key not found!${NC}"
                echo -e "${YELLOW}Run 'conn key create' to generate a new key pair.${NC}"
                return 1
            fi
            echo -e "${BLUE}=== SSH Public Key ===${NC}"
            echo ""
            cat "$pub_path"
            echo ""
            echo -e "${YELLOW}Path:${NC} $pub_path"
            echo ""
            ;;

        private)
            key_path="$(_default_private_key)"
            if [ -z "$key_path" ] || [ ! -f "$key_path" ]; then
                echo -e "${RED}Error: SSH private key not found!${NC}"
                echo -e "${YELLOW}Run 'conn key create' to generate a new key pair.${NC}"
                return 1
            fi

            echo -e "${RED}⚠  WARNING: You are about to display your PRIVATE key.${NC}"
            echo -e "${RED}   Never share it. Prefer 'conn key public' instead.${NC}"
            echo ""
            read -p "Type YES to continue: " confirm
            if [ "$confirm" != "YES" ]; then
                echo -e "${YELLOW}Operation cancelled.${NC}"
                return 0
            fi

            echo -e "${BLUE}=== SSH Private Key ===${NC}"
            echo ""
            cat "$key_path"
            echo ""
            echo -e "${YELLOW}Path:${NC} $key_path"
            echo ""
            ;;

        create)
            while [ $# -gt 0 ]; do
                case "$1" in
                    --rsa)
                        key_type="rsa"
                        shift
                        ;;
                    --ed25519)
                        key_type="ed25519"
                        shift
                        ;;
                    *)
                        echo -e "${RED}Error: unknown option '$1'${NC}"
                        echo "Usage: conn key create [--rsa]"
                        return 1
                        ;;
                esac
            done

            if [ "$key_type" = "rsa" ]; then
                new_key="$HOME/.ssh/id_rsa"
            else
                new_key="$HOME/.ssh/id_ed25519"
            fi

            if [ -f "$new_key" ]; then
                echo -e "${YELLOW}SSH key already exists at: $new_key${NC}"
                echo ""
                read -p "Do you want to overwrite it? (y/N): " confirm
                if [[ ! "$confirm" =~ ^[yY]$ ]]; then
                    echo -e "${YELLOW}Operation cancelled.${NC}"
                    if [ -f "${new_key}.pub" ]; then
                        echo ""
                        echo -e "${BLUE}Showing existing public key:${NC}"
                        echo ""
                        cat "${new_key}.pub"
                        echo ""
                    fi
                    return 0
                fi
            fi

            echo -e "${BLUE}=== Creating ${key_type} SSH Key Pair ===${NC}"
            echo ""
            mkdir -p "$HOME/.ssh"
            chmod 700 "$HOME/.ssh"

            comment="$(whoami)@$(hostname -s 2>/dev/null || hostname)"

            # Let ssh-keygen prompt for passphrase (do not force empty)
            if [ "$key_type" = "rsa" ]; then
                if ! ssh-keygen -t rsa -b 4096 -f "$new_key" -C "$comment"; then
                    echo -e "${RED}Error: failed to create SSH key pair!${NC}"
                    return 1
                fi
            else
                if ! ssh-keygen -t ed25519 -f "$new_key" -C "$comment"; then
                    echo -e "${RED}Error: failed to create SSH key pair!${NC}"
                    return 1
                fi
            fi

            echo ""
            echo -e "${GREEN}✓ SSH key pair created successfully!${NC}"
            echo ""
            echo -e "${BLUE}Your public key:${NC}"
            echo ""
            cat "${new_key}.pub"
            echo ""
            echo -e "${YELLOW}Path:${NC} $new_key"
            echo ""
            ;;

        *)
            echo -e "${RED}Error: unknown action '$action'${NC}"
            echo "Usage: conn key <public|private|create [--rsa]>"
            return 1
            ;;
    esac
}

check_for_updates() {
    # Throttle network checks (default: once per 24h)
    local now last=0
    now=$(date +%s 2>/dev/null) || return 0
    mkdir -p "$(dirname "$UPDATE_CACHE_FILE")" 2>/dev/null || true
    if [ -f "$UPDATE_CACHE_FILE" ]; then
        last=$(cat "$UPDATE_CACHE_FILE" 2>/dev/null) || last=0
        case "$last" in
            ''|*[!0-9]*) last=0 ;;
        esac
        if [ $((now - last)) -lt "$UPDATE_CACHE_TTL" ]; then
            return 0
        fi
    fi
    printf '%s\n' "$now" > "$UPDATE_CACHE_FILE" 2>/dev/null || true

    local tmp_file script_path
    tmp_file=$(mktemp) || return 0

    if ! _download_remote_script "$tmp_file" 2>/dev/null; then
        rm -f "$tmp_file"
        return 0
    fi

    if [ ! -s "$tmp_file" ]; then
        rm -f "$tmp_file"
        return 0
    fi

    if ! script_path="$(_resolve_script_path)"; then
        rm -f "$tmp_file"
        return 0
    fi

    if ! cmp -s "$script_path" "$tmp_file" 2>/dev/null; then
        echo ""
        echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${YELLOW}⚠  A new version of the script is available!${NC}"
        echo -e "${YELLOW}   Run 'conn update' to update to the latest version.${NC}"
        echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
    fi

    rm -f "$tmp_file"
}

update_script() {
    echo -e "${BLUE}=== Update SSH Connection Manager ===${NC}"
    echo ""

    local script_path
    if ! script_path="$(_resolve_script_path)"; then
        echo -e "${RED}Error: could not resolve script path!${NC}"
        return 1
    fi

    echo -e "Current script: ${YELLOW}$script_path${NC}"
    echo ""

    local need_sudo=false
    local script_dir
    script_dir="$(dirname "$script_path")"
    if [ ! -w "$script_path" ] || [ ! -w "$script_dir" ]; then
        need_sudo=true
        echo -e "${YELLOW}Note: This script is in a system directory and requires sudo.${NC}"
        echo ""
    fi

    local tmp_file staging
    tmp_file=$(mktemp) || return 1
    staging="${script_path}.new"

    echo "Downloading latest version from GitHub..."

    if ! _download_remote_script "$tmp_file"; then
        echo -e "${RED}Error: neither curl nor wget is available, or download failed!${NC}"
        rm -f "$tmp_file"
        return 1
    fi

    if [ ! -s "$tmp_file" ]; then
        echo -e "${RED}Error: failed to download the update!${NC}"
        rm -f "$tmp_file"
        return 1
    fi

    # Refuse to install a truncated / invalid script
    if ! head -n1 "$tmp_file" | grep -q '^#!'; then
        echo -e "${RED}Error: downloaded file does not look like a shell script — update aborted.${NC}"
        rm -f "$tmp_file"
        return 1
    fi
    if ! grep -q '^main "$@"' "$tmp_file"; then
        echo -e "${RED}Error: downloaded file looks incomplete — update aborted.${NC}"
        rm -f "$tmp_file"
        return 1
    fi
    if ! bash -n "$tmp_file" 2>/dev/null; then
        echo -e "${RED}Error: downloaded file failed syntax check — update aborted.${NC}"
        rm -f "$tmp_file"
        return 1
    fi

    if cmp -s "$script_path" "$tmp_file"; then
        echo ""
        echo -e "${GREEN}✓ Already up to date!${NC}"
        rm -f "$tmp_file"
        mkdir -p "$(dirname "$UPDATE_CACHE_FILE")" 2>/dev/null || true
        date +%s > "$UPDATE_CACHE_FILE" 2>/dev/null || true
        return 0
    fi

    echo -e "${GREEN}✓ New version downloaded${NC}"
    echo ""

    local install_ok=false
    if [ "$need_sudo" = true ]; then
        echo "Installing update (requires sudo)..."
        # Atomic replace: write to .new then mv over the target
        if sudo cp "$script_path" "${script_path}.backup"; then
            if sudo cp "$tmp_file" "$staging"; then
                if sudo chmod +x "$staging"; then
                    if sudo mv -f "$staging" "$script_path"; then
                        install_ok=true
                    fi
                fi
            fi
        fi
    else
        if ! cp "$script_path" "${script_path}.backup" 2>/dev/null; then
            echo -e "${YELLOW}Warning: could not create backup.${NC}"
        fi
        if cp "$tmp_file" "$staging"; then
            if chmod +x "$staging"; then
                if mv -f "$staging" "$script_path"; then
                    install_ok=true
                fi
            fi
        fi
    fi

    if [ "$install_ok" != true ]; then
        if [ "$need_sudo" = true ]; then
            sudo rm -f "$staging" 2>/dev/null
        else
            rm -f "$staging" 2>/dev/null
        fi
        echo -e "${RED}Error: failed to install update!${NC}"
        rm -f "$tmp_file"
        return 1
    fi

    # Verify the installed file; roll back if somehow invalid
    if ! bash -n "$script_path" 2>/dev/null; then
        echo -e "${RED}Error: installed file failed syntax check — restoring backup.${NC}"
        if [ -f "${script_path}.backup" ]; then
            if [ "$need_sudo" = true ]; then
                sudo cp "${script_path}.backup" "$script_path"
                sudo chmod +x "$script_path"
            else
                cp "${script_path}.backup" "$script_path"
                chmod +x "$script_path"
            fi
        fi
        rm -f "$tmp_file"
        return 1
    fi

    rm -f "$tmp_file"
    mkdir -p "$(dirname "$UPDATE_CACHE_FILE")" 2>/dev/null || true
    date +%s > "$UPDATE_CACHE_FILE" 2>/dev/null || true

    echo ""
    echo -e "${GREEN}✓ Script updated successfully!${NC}"
    if [ -f "${script_path}.backup" ]; then
        echo -e "${YELLOW}Note: A backup of the previous version was saved to:${NC}"
        echo "  ${script_path}.backup"
    fi
    echo ""
}

main() {
    if [ $# -eq 0 ]; then
        show_help
        return
    fi

    local cmd="$1"
    shift

    case "$cmd" in
        to)
            connect_to "$@"
            ;;
        list)
            list_connections "$@"
            ;;
        info)
            show_connection_info "$@"
            ;;
        add)
            add_connection "$@"
            ;;
        edit)
            edit_connection "$@"
            ;;
        remove)
            remove_connection "$@"
            ;;
        reset)
            reset_host "$@"
            ;;
        key)
            manage_keys "$@"
            ;;
        update)
            update_script
            ;;
        completion)
            print_completion "$@"
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            echo -e "${RED}Error: unknown command '$cmd'${NC}"
            echo ""
            show_help
            return 1
            ;;
    esac
}

main "$@"
